# Doxyfile.in — CMake template for Doxygen configuration

PROJECT_NAME = "SpMV GPU Optimization"
PROJECT_NUMBER = @PROJECT_VERSION@
OUTPUT_DIRECTORY = @CMAKE_CURRENT_BINARY_DIR@
INPUT = @PROJECT_SOURCE_DIR@/src/common \
         @PROJECT_SOURCE_DIR@/src/cpu \
         @PROJECT_SOURCE_DIR@/examples/example_spmv_basics.cpp

GENERATE_HTML = NO
GENERATE_XML = YES
XML_OUTPUT = @CMAKE_CURRENT_BINARY_DIR@/xml

SOURCE_BROWSER = YES
SHOW_INCLUDE_FILES = YES

OPTIMIZE_OUTPUT_JAVA = NO
OPTIMIZE_OUTPUT_FOR_C = NO
BUILTIN_STL_SUPPORT = YES
CPP_CLI_SUPPORT = NO
EXTRACT_ALL = YES
EXTRACT_PRIVATE = NO
EXTRACT_STATIC = YES

QUIET = YES