# Ignore .claude directory (local project files, notes, roadmap, etc.)
.claude/

# Ignore compiled binaries and objects
*.o
*.so
*.exe
*.out
build/

# Ignore IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Ignore temporary files
*.tmp
*.bak
*.log

# Ignore large data files (matrices, results, etc.)
data/

# Ignore Python cache
__pycache__/
*.pyc
*.pyo

# Ignore documentation build output
docs/_build/

# Ignore Python virtual environments for docs
.docs-venv/

# Ignore Visual Studio files
*.sln
*.vcxproj
*.vcxproj.filters

# Ignore CUDA build artifacts
*.cudafe1.c
*.cudafe1.cpp
*.fatbin
*.fatbin.c
*.module_id

# Ignore Serena AI tool files
.serena/

# Ignore OpenCode local configuration (contains SSH credentials)
.opencode/
.papers/
